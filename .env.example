# ============================================================
#  Gemma 4 12B  -  configuracion   (cp .env.example .env)
# ============================================================

# --- Hugging Face ---
# Con los defaults (Unsloth, NO gated) NO necesitas token. Solo hace falta
# HF_TOKEN si cambias MODEL al repo oficial de Google (gated).
HF_TOKEN=
HF_CACHE=${HOME}/.cache/huggingface

# --- Modelo (vLLM) ---
# DEFAULT de consumo: checkpoint w4a16 (QAT) de Unsloth, ~10GB, NO gated
# (sin token) y cabe en 16-24GB. vLLM detecta compressed-tensors solo.
# Alternativas:
#   - bf16 completo (GPU 40GB+):           unsloth/gemma-4-12b-it   (no gated)
#   - oficial de Google (gated, c/ token): google/gemma-4-12B-it
MODEL=unsloth/gemma-4-12B-it-qat-w4a16
SERVED_MODEL_NAME=gemma-4-12b
DTYPE=bfloat16

# --- Contexto y concurrencia ---
# El 12B soporta hasta 256K (262144). Default de consumo = 128K (cabe mejor en
# 16-24GB). Subelo a 200000/262144 si tienes memoria de sobra.
MAX_MODEL_LEN=131072
MAX_NUM_SEQS=3

# --- GPU / paralelismo (vLLM) ---
GPU_MEMORY_UTILIZATION=0.92
TENSOR_PARALLEL_SIZE=1
NVIDIA_GPU_COUNT=all

# --- Multimodal (vision + audio) ---
LIMIT_MM_PER_PROMPT={"image": 4, "audio": 1}
VISION_MAX_SOFT_TOKENS=280

# --- Agentes de codigo ---
ENABLE_TOOLS=1
CHAT_TEMPLATE=

# --- Red ---
PORT=8000

# --- Optimizacion vLLM (opcionales) ---
ASYNC_SCHEDULING=1
# Default de consumo: KV cache en fp8 (~50% menos memoria -> mas contexto).
KV_CACHE_DTYPE=fp8
# Workaround: algunos checkpoints w4a16 omiten vision_config.num_soft_tokens y
# vLLM crashea en multimodal. El entrypoint lo parchea (auto=280). off para desactivar.
PATCH_VISION_SOFT_TOKENS=auto
ROPE_SCALING=
# Normalmente vacio: vLLM detecta la cuantizacion (compressed-tensors) del
# checkpoint. Solo ponlo si tu modelo lo exige explicitamente.
QUANTIZATION=
VLLM_API_KEY=
EXTRA_ARGS=

# ============================================================
#  llama.cpp (perfiles llamacpp / llamacpp-cuda)
# ============================================================
# GGUF de Unsloth, se descarga solo con -hf (no gated).
# DEFAULT: QAT (Quantization-Aware Training) = calidad ~bf16 a 4-bit (~6.7GB).
#   Mejor relacion calidad/VRAM; deja mas memoria para el KV cache (contexto).
GGUF_HF_REPO=unsloth/gemma-4-12B-it-qat-GGUF
GGUF_QUANT=UD-Q4_K_XL
# Alternativa NO-QAT (si quieres Q5/Q6/Q8/BF16 o el draft MTP):
#   GGUF_HF_REPO=unsloth/gemma-4-12b-it-GGUF
#   GGUF_QUANT=Q4_K_M   # o Q5_K_M, Q6_K, Q8_0, UD-Q4_K_XL ...
LLAMACPP_CACHE=${HOME}/.cache/llama.cpp
# -c es el contexto TOTAL del server; se reparte entre --parallel slots.
# Default de consumo: 131072 (1 cliente=128K; con --parallel 3 = ~43K c/u).
# Si tu equipo tiene mucha RAM/VRAM, subelo (p.ej. 262144).
LLAMACPP_CTX=131072
# Extras de llama-server. Ejemplos:
#   Vision (mmproj se autodescarga con -hf; forzar otro:  --mmproj ...)
#   Speculative decoding con el draft MTP de Unsloth:
#     LLAMACPP_EXTRA=-md unsloth/gemma-4-12b-it-GGUF:MTP-Q8_0 --draft-max 8 --draft-min 1
#     (el draft MTP solo esta en el repo NO-qat; sirve igual como draft)
LLAMACPP_EXTRA=

# ============================================================
#  PRESETS POR ESCENARIO
# ============================================================
#
# >>> GPU NVIDIA de 40 GB+  (vLLM bf16) - perfil: cuda
#       MODEL=unsloth/gemma-4-12b-it   (sin cuantizar, no gated)
#       MAX_MODEL_LEN=200000   MAX_NUM_SEQS=3
#
# >>> GPU NVIDIA de consumo 16-24 GB
#   Opcion A (vLLM) - perfil: cuda   (es el DEFAULT del .env)
#       MODEL=unsloth/gemma-4-12B-it-qat-w4a16  (no gated)
#       KV_CACHE_DTYPE=fp8   MAX_MODEL_LEN=131072   MAX_NUM_SEQS=3
#   Opcion B (llama.cpp, mas simple) - perfil: llamacpp-cuda
#       (QAT por defecto)   LLAMACPP_CTX=131072   MAX_NUM_SEQS=3
#       (en 16 GB baja LLAMACPP_CTX si hay OOM; el KV cache es lo que pesa)
#
# >>> GPU/iGPU AMD o Intel de consumo - perfil: llamacpp (Vulkan)
#       (QAT por defecto)   LLAMACPP_CTX=262144   MAX_NUM_SEQS=3
#       (vLLM-ROCm solo soporta GPUs Instinct MI300X+, no las de consumo)
#
# >>> Apple Silicon (Mac) - NO Docker, nativo (ver README)
#       llama-server -hf unsloth/gemma-4-12B-it-qat-GGUF:UD-Q4_K_XL \
#         -c 65536 --parallel 1 -ngl 999 --jinja
#
# >>> Memoria justa / 1 solo cliente
#       MAX_NUM_SEQS=1 (vLLM) o --parallel 1 (llama.cpp)
#       Baja el contexto (p.ej. MAX_MODEL_LEN=32768 / LLAMACPP_CTX=32768)
#       y activa KV_CACHE_DTYPE=fp8 en vLLM.
