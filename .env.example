# ============================================================
#  Gemma 4 12B  -  configuracion   (cp .env.example .env)
# ============================================================

# --- Hugging Face (el repo de Google es gated; el de Unsloth NO) ---
HF_TOKEN=
HF_CACHE=${HOME}/.cache/huggingface

# --- Modelo (vLLM) ---
MODEL=google/gemma-4-12B-it
SERVED_MODEL_NAME=gemma-4-12b
DTYPE=bfloat16

# --- Contexto y concurrencia ---
# El 12B soporta hasta 256K (262144). 200K cabe de sobra.
MAX_MODEL_LEN=200000
MAX_NUM_SEQS=3

# --- GPU / paralelismo (vLLM) ---
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
NVIDIA_GPU_COUNT=all

# --- Multimodal (vision + audio) ---
LIMIT_MM_PER_PROMPT={"image": 4, "audio": 1}
VISION_MAX_SOFT_TOKENS=280

# --- Agentes de codigo ---
ENABLE_TOOLS=1
CHAT_TEMPLATE=

# --- Red ---
PORT=8000

# --- Optimizacion vLLM (opcionales) ---
ASYNC_SCHEDULING=1
KV_CACHE_DTYPE=
ROPE_SCALING=
QUANTIZATION=
VLLM_API_KEY=
EXTRA_ARGS=

# ============================================================
#  llama.cpp (perfiles llamacpp / llamacpp-cuda)
# ============================================================
# GGUF de Unsloth, se descarga solo con -hf (no gated).
# DEFAULT: QAT (Quantization-Aware Training) = calidad ~bf16 a 4-bit (~6.7GB).
#   Mejor relacion calidad/VRAM; deja mas memoria para el KV cache (contexto).
GGUF_HF_REPO=unsloth/gemma-4-12B-it-qat-GGUF
GGUF_QUANT=UD-Q4_K_XL
# Alternativa NO-QAT (si quieres Q5/Q6/Q8/BF16 o el draft MTP):
#   GGUF_HF_REPO=unsloth/gemma-4-12b-it-GGUF
#   GGUF_QUANT=Q4_K_M   # o Q5_K_M, Q6_K, Q8_0, UD-Q4_K_XL ...
LLAMACPP_CACHE=${HOME}/.cache/llama.cpp
# -c es el contexto TOTAL del server; se reparte entre --parallel slots.
# 262144 con --parallel 3 = ~87K por cliente. Para 200K/cliente: 200000 + parallel 1.
LLAMACPP_CTX=262144
# Extras de llama-server. Ejemplos:
#   Vision (mmproj se autodescarga con -hf; forzar otro:  --mmproj ...)
#   Speculative decoding con el draft MTP de Unsloth:
#     LLAMACPP_EXTRA=-md unsloth/gemma-4-12b-it-GGUF:MTP-Q8_0 --draft-max 8 --draft-min 1
#     (el draft MTP solo esta en el repo NO-qat; sirve igual como draft)
LLAMACPP_EXTRA=

# ============================================================
#  PRESETS POR EQUIPO
# ============================================================
#
# >>> RTX 5070 Ti (16GB)
#   Opcion A (max throughput) - perfil: cuda  (vLLM)
#     bf16 NO cabe -> usa checkpoint w4a16:
#       MODEL=<repo-w4a16>   QUANTIZATION=compressed-tensors
#       KV_CACHE_DTYPE=fp8   MAX_MODEL_LEN=200000   MAX_NUM_SEQS=3
#   Opcion B (mas simple) - perfil: llamacpp-cuda  (llama.cpp GGUF)
#       GGUF_QUANT=UD-Q4_K_XL  (QAT)  LLAMACPP_CTX=131072  MAX_NUM_SEQS=3
#       (en 16GB, baja LLAMACPP_CTX si OOM; el KV cache es lo que pesa)
#
# >>> Ryzen 8700G + 64GB (iGPU 780M) - perfil: llamacpp  (Vulkan)
#       GGUF_QUANT=UD-Q4_K_XL  (QAT)  LLAMACPP_CTX=262144  MAX_NUM_SEQS=3
#       (vLLM-ROCm NO soporta el 780M)
#
# >>> MBP M4 Pro (24GB) - NO Docker, nativo (ver README)
#       llama-server -hf unsloth/gemma-4-12B-it-qat-GGUF:UD-Q4_K_XL \
#         -c 196608 --parallel 3 -ngl 999 --jinja
